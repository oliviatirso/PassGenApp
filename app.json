{
  "expo": {
    "name": "PassGen Pro",
    "slug": "pass2",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#7B5CE5"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.passgen.pro",
      "infoPlist": {
        "NSFaceIDUsageDescription": "PassGen Pro uses Face ID to protect your saved passwords in the vault."
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#7B5CE5"
      },
      "package": "com.passgen.pro"
    },
    "web": {
      "favicon": "./assets/favicon.png"
    }
  }
}
